{
  "name": "photo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && tsc -p functions && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "wrangler pages deploy ./dist",
    "db:local": "wrangler d1 execute photo-db --local --file=./db/schema.sql",
    "db:remote": "wrangler d1 execute photo-db --remote --file=./db/schema.sql",
    "db:studio": "wrangler d1 execute photo-db --local --command=\"SELECT 'D1 Studio ready'\""
  },
  "dependencies": {
    "@stripe/stripe-js": "^9.8.0",
    "@tanstack/react-query": "^5.75.5",
    "clsx": "^2.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-filerobot-image-editor": "^5.0.0-beta.159",
    "react-router-dom": "^7.6.0",
    "tailwind-merge": "^3.2.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260611.1",
    "@tailwindcss/vite": "^4.1.10",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.4.1",
    "tailwindcss": "^4.1.10",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vitest": "^4.1.9",
    "wrangler": "^4.14.0"
  }
}
