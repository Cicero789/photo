# FrameNest v2 — Required Secrets
# Copy to .dev.vars for local development

# Authentication
JWT_SECRET=your-jwt-secret-here
MEDIA_SIGNING_SECRET=your-media-signing-secret-here

# Stripe
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxx

# Mapbox
MAPBOX_API_KEY=pk.xxx

# AI
DEEPSEEK_API_KEY=sk-xxx
OPENAI_API_KEY=sk-xxx

# Email (ZeptoMail / Zoho)
ZOHO_API_KEY=xxx
EMAIL_FROM=noreply@framenest.photos

# Cloudflare
CLOUDFLARE_API_KEY=xxx
CLOUDFLARED1R1_API_KEY=xxx

# GitHub
GITHUB_API_KEY=ghp_xxx
