# Required — set via Cloudflare Pages secrets:
#   wrangler pages secret put JWT_SECRET --project-name photo
#   wrangler pages secret put DEEPSEEK_API_KEY --project-name photo
#   wrangler pages secret put RESEND_API_KEY --project-name photo
#
# JWT_SECRET: used to sign authentication tokens (32+ characters)
# DEEPSEEK_API_KEY: used for AI event summaries (sk-... from platform.deepseek.com)
# RESEND_API_KEY: used to send password-reset emails (re_... from resend.com/api-keys)
#
# EMAIL_FROM (optional): sender address for outgoing email.
#   Defaults to "Photo <onboarding@resend.dev>", which can ONLY deliver to the
#   Resend account owner's own inbox. To email real users, verify a domain you
#   own in Resend (add its DNS records in Cloudflare) and set:
#   wrangler pages secret put EMAIL_FROM --project-name photo
#   e.g. EMAIL_FROM="Photo <no-reply@yourdomain.com>"
#   Note: *.pages.dev addresses cannot be verified (Cloudflare owns that DNS).
#
# The .env file is NOT loaded by Cloudflare Pages Functions.
# Use `wrangler pages secret put` for production secrets.

# Mapbox public token (used in frontend — src/components/map/EventMap.tsx)
# Create a public token at https://account.mapbox.com/access-tokens
# MAPBOX_PUBLIC_TOKEN=pk.eyJ1Ijoi...

# Cloudflare
# CLOUDFLARE_API_KEY=cfut_...

# GitHub
# GITHUB_API_KEY=ghp_...

# OpenAI (reserved)
# OPENAI_API_KEY=sk-proj-...
